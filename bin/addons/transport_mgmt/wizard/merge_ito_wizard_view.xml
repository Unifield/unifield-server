<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record id="view_merge_ito_wizard" model="ir.ui.view">
            <field name="name">Merge Inbound Transport Objects</field>
            <field name="model">merge.ito.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Merge ITOs">
                    <separator string="Are you sure you want to merge these ITOs ?" colspan="4"/>
                    <newline/>
                    <group colspan="4">
                        <html>
                            <p><translate>Please note that the Inbound Transport Objects will only be merged if: </translate></p>
                            <ul>
                                <li><translate>They have the same state and are in the state: Draft, Planned, Pre-Arrival, In Transit or At Customs Entry Point</translate></li>
                                <li><translate>They have the International Zone Type</translate></li>
                                <li><translate>They have the same Supplier Partner</translate></li>
                                <li><translate>They have the same Shipment Flow</translate></li>
                                <li><translate>They have the same Original Cargo ref</translate></li>
                            </ul>
                        </html>
                    </group>
                    <separator colspan="4" />
                    <group colspan="4">
                        <field name="ito_template_id" readonly="1" colspan="2" />
                        <newline />
                        <html colspan="4">
                            <p>
                                <translate>
                                    All information of the ITO template will be written in the new ITO, except the Cargo Type which will depend on the template and merged ITO data.<br/>If they are identical the merged Cargo Type will be the same, but if they are not the merged Cargo Type will be Mixed.<br/>A Cargo Type will also be shown on the Lines of the merged ITO.
                                </translate>
                            </p>
                        </html>
                        <newline />
                        <group colspan="4" col="4" attrs="{'invisible': [('cant_merge_msg', '=', False)]}">
                            <html colspan="4">
                                <p style="margin:10px 0 10px 0;padding-left:5px;border-style:solid;border-width:1px;border-radius:5px;">
                                    <div style="font-weight:bold;color:red"><translate>IMPOSSIBLE TO MERGE:</translate></div>
                                    <div><field name="cant_merge_msg" nolabel="1" /></div>
                                </p>
                            </html>
                        </group>
                    </group>
                    <newline/>
                    <separator string="" colspan="4" />
                    <button special="cancel" string="Cancel" icon="gtk-cancel"/>
                    <button name="merge_ito" string="Merge ITOs" type="object" icon="gtk-convert" attrs="{'readonly': [('cant_merge_msg', '!=', '')]}"/>
                </form>
            </field>
        </record>

        <act_window name="Merge ITOs"
            res_model="merge.ito.wizard"
            src_model="transport.order.in"
            view_mode="form"
            view_ids="transport_order_in_tree"
            target="new"
            multi="True"
            key2="client_action_multi"
            id="action_view_merge_ito_wizard"/>
    </data>
</openerp>
