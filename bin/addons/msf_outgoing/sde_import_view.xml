<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data noupdate="1">
        <!-- SDE User -->
        <record model="res.users" id="base.user_sde_tool">
            <field name="name">SDE Tool</field>
            <field name="login">sde_tool</field>
            <field name="active" eval="False" />
        </record>

        <!-- Sequences for sde.export.pagination -->
        <record id="seq_type_sde_export_pagination" model="ir.sequence.type">
            <field name="name">SDE Paginated Exports</field>
            <field name="code">sde.export.pagination</field>
        </record>
        <record id="seq_sde_export_pagination" model="ir.sequence">
            <field name="name">SDE Paginated Exports</field>
            <field name="code">sde.export.pagination</field>
            <field name="prefix">SDE/EXPORT</field>
            <field name="padding">6</field>
            <field name="implementation">psql</field>
        </record>
    </data>

    <data>
        <record id="sde_import_form_view" model="ir.ui.view">
            <field name="name">sde.import.form.view</field>
            <field name="model">sde.import</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="SDE Tools" hide_new_button="1" hide_save_button="1" hide_duplicate_button="1" hide_delete_button="1" hide_cancel_button="1">
                    <separator colspan="4" string="Data for the imports/tools" />
                    <field name="json_text" colspan="4" />
                    <field name="message" readonly="1" colspan="4" />
                    <separator colspan="4" string="Import IN Tools" />
                    <button name="wizard_sde_import_in" string="Import IN" icon="gtk-execute" type="object" colspan="2" />
                    <button name="wizard_sde_import_in_updated" string="Import IN Updated" icon="gtk-execute" type="object" colspan="2" />
                    <separator colspan="4" string="Add attachment to an IN" />
                    <group colspan="4" col="6">
                        <field name="po_ref_for_in" />
                        <field name="pack_ref_for_in" />
                        <field name="partner_fo_ref_for_in" />
                    </group>
                    <group colspan="4">
                        <field name="file" filename="filename" />
                        <field name="filename" invisible="1" />
                        <button name="wizard_sde_file_to_in" string="Import attachment" icon="gtk-execute" type="object" colspan="1" />
                    </group>
                    <separator colspan="4" string="Picking Ticket Tools" />
                    <button name="wizard_sde_picking_ticket_import" string="Import Picking Ticket" icon="gtk-execute" type="object" colspan="2" />
                    <button name="wizard_sde_picking_ticket_msg" string="Set banner on Picking Tickets" icon="gtk-execute" type="object" colspan="2" />
                    <button name="wizard_sde_picking_ticket_export" string="Export Picking Tickets" icon="gtk-execute" type="object" colspan="2" />
                    <button name="wizard_sde_picking_ticket_export_lines" string="Export Picking Tickets with lines" icon="gtk-execute" type="object" colspan="2" />
                    <separator colspan="4" string="Report Actions" />
                    <button name="generate_sde_dispatched_packing_list_report" string="Generate Dispatched Packing List report" icon="gtk-print" type="object" colspan="4" context="{'from_sde_wizard': True}" />
                </form>
            </field>
        </record>

        <menuitem name="Single Data Entry" parent="object_query.menu_preferences" id="sde_import_main_menu" sequence="20" />

        <record id="action_sde_import" model="ir.actions.act_window">
            <field name="name">SDE Tools</field>
            <field name="res_model">sde.import</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
        </record>
        <menuitem name="SDE Tools" action="action_sde_import" id="sde_import_menu" parent="sde_import_main_menu" />

        <record id="sde_import_pagination_search_view" model="ir.ui.view">
            <field name="name">sde.import.pagination.search.view</field>
            <field name="model">sde.import.pagination</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="SDE Paginated imports">
                    <filter string="In Progress" icon="terp-stock_effects-object-colorize" domain="[('state', '=', 'in_progress')]" />
                    <filter string="Done" icon="gtk-close" domain="[('state','=','done')]" />
                    <separator orientation="vertical"/>
                    <field name="pagination_json_id" />
                </search>
            </field>
        </record>

        <record id="sde_import_pagination_tree_view" model="ir.ui.view">
            <field name="name">sde.import.pagination.tree.view</field>
            <field name="model">sde.import.pagination</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="SDE Paginated imports" hide_new_button="1" hide_edit_button="1" hide_delete_button="1">
                    <field name="pagination_json_id"/>
                    <field name="last_modification"/>
                    <field name="state"/>
                    <field name="page"/>
                </tree>
            </field>
        </record>

        <record id="sde_import_pagination_form_view" model="ir.ui.view">
            <field name="name">sde.import.pagination.form.view</field>
            <field name="model">sde.import.pagination</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="SDE Paginated import" hide_new_button="1" hide_edit_button="1" hide_delete_button="1">
                    <field name="pagination_json_id"/>
                    <field name="last_modification"/>
                    <field name="state"/>
                    <field name="page"/>
                    <field name="pagination_json_text" colspan="4"/>
                </form>
            </field>
        </record>

        <record id="action_sde_paginated_import" model="ir.actions.act_window">
            <field name="name">SDE Paginated imports</field>
            <field name="res_model">sde.import.pagination</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="SDE Paginated imports" action="action_sde_paginated_import" id="sde_paginated_import_menu" parent="sde_import_main_menu" sequence="11" />

        <record id="sde_export_pagination_search_view" model="ir.ui.view">
            <field name="name">sde.export.pagination.search.view</field>
            <field name="model">sde.export.pagination</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="SDE Paginated exports">
                    <field name="pagination_json_id" />
                    <field name="doc_type" />
                    <field name="with_lines" />
                </search>
            </field>
        </record>

        <record id="sde_export_pagination_tree_view" model="ir.ui.view">
            <field name="name">sde.export.pagination.tree.view</field>
            <field name="model">sde.export.pagination</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="SDE Paginated exports" hide_new_button="1" hide_edit_button="1" hide_delete_button="1">
                    <field name="pagination_json_id"/>
                    <field name="doc_type"/>
                    <field name="page"/>
                    <field name="last_page"/>
                    <field name="with_lines"/>
                </tree>
            </field>
        </record>

        <record id="sde_export_pagination_form_view" model="ir.ui.view">
            <field name="name">sde.export.pagination.form.view</field>
            <field name="model">sde.export.pagination</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="SDE Paginated export" hide_new_button="1" hide_edit_button="1" hide_delete_button="1">
                    <field name="pagination_json_id"/>
                    <field name="doc_type"/>
                    <field name="page"/>
                    <field name="last_page"/>
                    <field name="with_lines"/>
                    <field name="pagination_json_text" colspan="4"/>
                </form>
            </field>
        </record>

        <record id="action_sde_paginated_export" model="ir.actions.act_window">
            <field name="name">SDE Paginated exports</field>
            <field name="res_model">sde.export.pagination</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="SDE Paginated exports" action="action_sde_paginated_export" id="sde_paginated_export_menu" parent="sde_import_main_menu" sequence="12" />

        <record id="sde_update_log_search_view" model="ir.ui.view">
            <field name="name">sde.update.log.search.view</field>
            <field name="model">sde.update.log</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="SDE Update Logs">
                    <field name="date" />
                    <field name="doc_type" select="1" />
                    <field name="doc_ref" />
                </search>
            </field>
        </record>

        <record id="sde_update_log_tree_view" model="ir.ui.view">
            <field name="name">sde.update.log.tree.view</field>
            <field name="model">sde.update.log</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="SDE Update Logs" hide_new_button="1" hide_edit_button="1" hide_delete_button="1">
                    <field name="date"/>
                    <field name="doc_type"/>
                    <field name="doc_ref"/>
                </tree>
            </field>
        </record>

        <record id="action_sde_update_log" model="ir.actions.act_window">
            <field name="name">SDE Update Logs</field>
            <field name="res_model">sde.update.log</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree</field>
        </record>

        <menuitem
            id="menu_sde_update_log"
            action="action_sde_update_log"
            parent="stock.next_id_61"
            sequence="110"
            />
    </data>
</openerp>
